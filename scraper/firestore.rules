rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    /// True if the request is from a signed-in user.
    function isAuthed() {
      return request.auth != null;
    }

    /// True if the signed-in user owns the document (by ownerId field).
    function isOwner(ownerId) {
      return isAuthed() && request.auth.uid == ownerId;
    }

    /// True if the incoming write does NOT change the ownerId field.
    function ownerUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    // ── Vehicles ────────────────────────────────────────────────────────────
    // Each user may own exactly one vehicle document.
    // Only the owner can read or write their vehicle.

    match /vehicles/{vehicleId} {
      allow read:   if isOwner(resource.data.ownerId);
      allow create: if isAuthed()
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data.ownerId)
                    && ownerUnchanged();
      allow delete: if isOwner(resource.data.ownerId);

      // ── Service Logs (subcollection) ──────────────────────────────────────
      // Only the vehicle owner can read or write their service logs.

      match /serviceLogs/{logId} {
        allow read, write: if isAuthed()
          && get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.ownerId
             == request.auth.uid;
      }
    }

    // ── Build Gallery ───────────────────────────────────────────────────────
    // Any authenticated user can read posts.
    // Only the post author can update or delete their post.

    match /buildPosts/{postId} {
      allow read:   if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 100
                    && request.resource.data.imageUrl is string;
      allow update: if isAuthed()
                    && resource.data.userId == request.auth.uid
                    // Allow likeCount increments from anyone (like system)
                    || (isAuthed()
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['likeCount']));
      allow delete: if isAuthed()
                    && resource.data.userId == request.auth.uid;

      // ── Likes (subcollection) ─────────────────────────────────────────────
      // Any authed user can like/unlike. They can only write their own like doc.

      match /likes/{userId} {
        allow read:   if isAuthed();
        allow write:  if isAuthed() && request.auth.uid == userId;
      }
    }

    // ── Parts (Marketplace) ─────────────────────────────────────────────────
    // Parts are read-only for all authenticated users.
    // Only populated server-side via the Python scraper + Admin SDK
    // (Admin SDK bypasses security rules entirely — this blocks client writes).

    match /parts/{partId} {
      allow read:  if isAuthed();
      allow write: if false; // Admin SDK only
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
